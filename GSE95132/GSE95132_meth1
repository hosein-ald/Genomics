  match(rownames(ann_GSE77955_df), rownames(mat_quad))]
ann_GSE77955_df$mean_normal_quad <- rowMeans(mat_quad[, NORMAL_SAMPLES, drop = FALSE])[
  match(rownames(ann_GSE77955_df), rownames(mat_quad))]

