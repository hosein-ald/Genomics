# ── SECTION 7: FISHER TEST — HYPER vs HYPO ENRICHMENT AT G4 SITES ────────────
# NOTE: This is a DIFFERENT question from run_fisher_covered() in
# methylation_pipeline_clean.R. That test asks whether G4 sites are enriched
# among DMCs vs background CpGs. This test asks whether the G4 overlap rate
# differs between hypermethylated and hypomethylated probes/sites.
# Contingency table:
#         overlap  no_overlap
#  hyper:   a         b
#  hypo:    c         d

run_overlap_fisher <- function(hyper_set, hypo_set,
                               hyper_overlap, hypo_overlap,
                               test_name = "test") {
  a <- nrow(dplyr::distinct(hyper_overlap))
  c <- nrow(dplyr::distinct(hypo_overlap))
  b <- nrow(dplyr::distinct(hyper_set)) - a
  d <- nrow(dplyr::distinct(hypo_set))  - c

  mat <- matrix(c(a, b, c, d), nrow = 2, byrow = TRUE,
                dimnames = list(c("hyper","hypo"), c("overlap","no_overlap")))

  ft <- fisher.test(mat, alternative = "two.sided")

  cat("\n══", test_name, "══\n")
  print(mat)
  cat("Row proportions:\n"); print(round(prop.table(mat, 1), 4))
  cat("Fisher OR:", round(ft$estimate, 4), "| p:", ft$p.value, "\n")

  invisible(list(table = mat, fisher = ft))
}

