  ann_GSE77955_df[ann_GSE77955_df$pos %in% Quadron_probe_pos, ])
cat("Probes inside Quadron peaks:", length(Quadron_probe_ids), "\n")

mat_quad <- beta[rownames(beta) %in% Quadron_probe_ids, ]

