  ann_GSE77955_df[ann_GSE77955_df$pos %in% BG4_e5PE_probe_pos, ])
cat("Probes inside BG4 e5 peaks:", length(BG4_e5PE_probe_ids), "\n")

mat_BG4 <- beta[rownames(beta) %in% BG4_e5PE_probe_ids, ]

# Compute mean beta per group for BG4 probes
ann_GSE77955_df$mean_tumor_BG4  <- rowMeans(mat_BG4[, TUMOR_SAMPLES,  drop = FALSE])[
  match(rownames(ann_GSE77955_df), rownames(mat_BG4))]
ann_GSE77955_df$mean_normal_BG4 <- rowMeans(mat_BG4[, NORMAL_SAMPLES, drop = FALSE])[
  match(rownames(ann_GSE77955_df), rownames(mat_BG4))]

# Quadron probes
Quadron_probe_pos <- intersect(ann_GSE77955_df$pos, cpg_quadron_df$start)
