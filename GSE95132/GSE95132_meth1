# ── SECTION 3: CpG DINUCLEOTIDE EXTRACTION FROM PEAK INTERVALS ───────────────
# For each peak set, fetch the genomic sequence and locate all "CG" dinucleotides.
# Output: a 0-based BED file of CpG positions within G4 peaks.
# These files are used as the BG4 CpG sets in methylation_pipeline_clean.R.

# Helper: extract CpGs from a GRanges object using BSgenome
extract_cpgs_from_gr <- function(gr, label = "") {
  seqs <- getSeq(BSgenome.Hsapiens.UCSC.hg19, gr)
  hits <- lapply(seq_along(seqs), function(i) {
    m <- matchPattern("CG", seqs[[i]])
    if (length(m) == 0) return(NULL)
    data.frame(
      chrom       = as.character(seqnames(gr)[i]),
      start       = start(gr)[i] + start(m) - 1L,   # 1-based genomic
      end         = start(gr)[i] + start(m),
      interval_id = i
    )
  })
  df <- do.call(rbind, hits)
  df$start <- as.integer(df$start) - 1L   # convert to 0-based BED
  df$end   <- as.integer(df$end)   - 1L
  cat(label, "— CpGs extracted:", nrow(df), "\n")
  df
}

