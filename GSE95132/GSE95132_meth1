# ── SECTION 8: MEAN METHYLATION AT G4 CpGs ───────────────────────────────────
# For 450k array data (GSE77955): identify which probes fall inside BG4 / Quadron
# peaks and compute per-group mean beta values.

# Find probes overlapping BG4 e5 peaks
BG4_e5PE_probe_pos <- intersect(ann_GSE77955_df$pos, cpg_df_e5PE$start)
